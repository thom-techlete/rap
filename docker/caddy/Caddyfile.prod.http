# Production HTTP-only Caddyfile - for use behind a TLS-terminating load balancer

:80 {
encode gzip

header {
X-Frame-Options DENY
X-Content-Type-Options nosniff
X-XSS-Protection "1; mode=block"
Referrer-Policy "strict-origin-when-cross-origin"
Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self';"
}

request_body {
max_size 5MB
}

handle /static/* {
root * /app
file_server
header Cache-Control "public, max-age=2592000, immutable"
}

handle /media/* {
root * /app
file_server
header Cache-Control "public, max-age=604800"
}

handle /health {
reverse_proxy web:8000 {
header_up Host {host}
header_up X-Real-IP {remote_host}
}
}

handle /health/* {
reverse_proxy web:8000 {
header_up Host {host}
header_up X-Real-IP {remote_host}
}
}

handle {
reverse_proxy web:8000 {
header_up Host {host}
header_up X-Real-IP {remote_host}
}
}

handle_errors {
@400 expression `{http.error.status_code} == 400`
@403 expression `{http.error.status_code} == 403`
@404 expression `{http.error.status_code} == 404`
@502 expression `{http.error.status_code} == 502`
@5xx expression `{http.error.status_code} >= 500 && {http.error.status_code} != 502`

handle @400 {
root * /etc/caddy/error-pages
rewrite * /400.html
file_server
}
handle @403 {
root * /etc/caddy/error-pages
rewrite * /403.html
file_server
}
handle @404 {
root * /etc/caddy/error-pages
rewrite * /404.html
file_server
}
handle @502 {
root * /etc/caddy/error-pages
rewrite * /502.html
file_server
}
handle @5xx {
root * /etc/caddy/error-pages
rewrite * /500.html
file_server
}
}

log {
output file /var/log/caddy/access.log
format json
}
}
